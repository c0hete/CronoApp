# =====================================================================
# Crono — plantilla de entorno de PRODUCCIÓN (hub, detrás de NPM)
# Copiar a .env EN EL SERVER y completar. NUNCA versionar el .env real.
# Genera APP_KEY y DB_PASSWORD en el server (no acá, no en el chat).
# =====================================================================

APP_NAME=Crono
APP_ENV=production
APP_KEY=                                  # openssl rand -base64 32 → base64:... (en el server)
APP_DEBUG=false
APP_URL=https://cronoapp.alvaradomazzei.cl
ASSET_URL=https://cronoapp.alvaradomazzei.cl   # OBLIGATORIO o los assets salen en http (mixed content)

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL
APP_TIMEZONE=America/Santiago

# Cliente/instancia (Fugo Sushi = empresa_id 1 de ESTA instancia)
CRONO_EMPRESA_ID=1

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Base de datos (MySQL 8 interno; host = nombre del servicio del compose) ---
DB_CONNECTION=mysql
DB_HOST=crono_db
DB_PORT=3306
DB_DATABASE=crono
DB_USERNAME=crono
DB_PASSWORD=                              # generar en el server (28+ chars aleatorios)

# --- Sesión / caché / cola ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Cálculo / fotos (defaults; lo fino vive en tabla configuraciones) ---
CRONO_CORTE_SEMANA=lunes
CRONO_BASE_CALCULO=bruto
CRONO_FOTOS_RETENCION_DIAS=60
CRONO_FOTOS_DISK=fotos

# --- Mail (opcional; el hub usa mail.alvaradomazzei.cl si se habilita) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@cronoapp.cl"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_HOST=mail.alvaradomazzei.cl
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# --- Notificaciones (Telegram, Fase 2) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
