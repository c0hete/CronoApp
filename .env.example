# =====================================================================
# Crono — plantilla de entorno (.env.example)
# Producto SaaS, instancia dedicada por cliente. Copiar a .env y completar.
# NUNCA poner secretos reales acá. Lo específico de cliente va en .env / tabla configuraciones.
# =====================================================================

APP_NAME=Crono
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CL
APP_TIMEZONE=America/Santiago

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# Cliente/instancia (identifica el tenant de ESTA instancia; default empresa_id=1)
CRONO_EMPRESA_ID=1

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Base de datos (una por instancia; host = servicio Docker "mysql") ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crono
DB_USERNAME=crono
DB_PASSWORD=

# --- Sesión / caché / cola ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Cálculo (defaults; lo fino vive en tabla configuraciones) ---
CRONO_CORTE_SEMANA=lunes
CRONO_BASE_CALCULO=bruto

# --- Retención de fotos (evidencia visual, NO biometría) ---
CRONO_FOTOS_RETENCION_DIAS=60
CRONO_FOTOS_DISK=local

# --- Notificaciones (push PWA principal; Telegram/email secundarios) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@cronoapp.cl"
MAIL_FROM_NAME="${APP_NAME}"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

VITE_APP_NAME="${APP_NAME}"
